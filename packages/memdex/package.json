{
  "name": "memdex",
  "version": "0.1.6",
  "description": "Agent-facing semantic locator for local projects and source sets using NotebookLM, repomix snapshots, freshness checks, and local verification.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/yoyooyooo/memdex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yoyooyooo/memdex.git",
    "directory": "packages/memdex"
  },
  "bugs": {
    "url": "https://github.com/yoyooyooo/memdex/issues"
  },
  "keywords": [
    "agent",
    "corpus",
    "notebooklm",
    "project-memory",
    "repomix",
    "retrieval",
    "semantic-search"
  ],
  "bin": {
    "memdex": "bin/memdex.js"
  },
  "files": [
    "bin/memdex.js",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/cli.ts --target=node --format=esm --packages=external --outdir=dist",
    "memdex": "bun ./src/cli.ts",
    "check": "bun test && bun run build && node ./bin/memdex.js --help >/dev/null",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "yaml": "^2.9.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  }
}
